{
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "types": ["node"]
  },
  "include": [
    "eslint.config.js",
    "playwright.config.ts",
    "tests/e2e/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
